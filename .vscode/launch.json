{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Play",
      "type": "gdb",
      "request": "launch",
      "program": "main",
      "args": [
        "play",
        "-w"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable gdb pretty print",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build",
      "internalConsoleOptions": "openOnSessionStart"
    }
  ]
}
