{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Make clean",
      "type": "shell",
      "command": "make",
      "args": [
        "clean"
      ],
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Make all",
      "type": "shell",
      "command": "make",
      "args": [
        "all"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Build",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Make clean",
        "Make all"
      ]
    }
  ]
}
